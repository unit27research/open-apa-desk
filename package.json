{
  "name": "open-apa-desk",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "A free, privacy-first APA 7 helper for Google Docs.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/unit27research/open-apa-desk.git"
  },
  "bugs": {
    "url": "https://github.com/unit27research/open-apa-desk/issues"
  },
  "homepage": "https://unit27research.github.io/open-apa-desk/",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "assets:brand": "node scripts/generate-brand-assets.mjs",
    "site:build": "node scripts/build-public-site.mjs",
    "release:check": "node scripts/check-release-readiness.mjs",
    "marketplace:assets:final": "node scripts/check-release-readiness.mjs --final-screenshots",
    "marketplace:drafts:check": "node scripts/check-marketplace-drafts.mjs",
    "publish:archive": "node scripts/create-publish-archive.mjs",
    "upload:preflight": "node scripts/check-upload-readiness.mjs",
    "crossref:smoke": "node scripts/smoke-crossref.mjs",
    "smoke:evidence": "node scripts/create-smoke-evidence.mjs",
    "smoke:evidence:check": "node scripts/check-smoke-evidence.mjs",
    "smoke:exports": "node scripts/check-smoke-exports.mjs",
    "submission:preflight": "node scripts/check-submission-readiness.mjs",
    "build": "node scripts/build.mjs",
    "build:check": "node scripts/check-apps-script-bundle.mjs",
    "clasp:login": "clasp login",
    "clasp:push": "npm run build && npm run build:check && clasp push --force",
    "verify": "npm run assets:brand && npm run site:build && npm run release:check && npm run typecheck && npm run test && npm run build && npm run build:check"
  },
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "@types/google-apps-script": "^2.0.9",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
